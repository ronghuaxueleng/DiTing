{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DiTing Worker Manager",
  "version": "0.1.0",
  "identifier": "com.diting.worker-manager",
  "build": {
    "beforeBuildCommand": "cd frontend && npm run build",
    "beforeDevCommand": "cd frontend && npm run dev -- --port 5173",
    "devUrl": "http://localhost:5173/worker-manager.html",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DiTing Worker Manager",
        "url": "/worker-manager.html",
        "width": 900,
        "height": 640,
        "minWidth": 800,
        "minHeight": 560,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "./resources/**/*",
      "../asr_worker/**/*"
    ]
  }
}
